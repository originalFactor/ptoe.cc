{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hexo: Create Images Folder",
      "type": "shell",
      // Windows 系统的 PowerShell 路径替换逻辑
      "windows": {
        "options": {
          "shell": {
            "executable": "powershell.exe",
            "args": ["-Command"]
          }
        },
        "command": "$mdDir = '${fileDirname}'; $postName = '${fileBasenameNoExtension}'; $imgDir = $mdDir -replace '_posts', 'images'; $target = Join-Path $imgDir $postName; New-Item -ItemType Directory -Force -Path $target"
      },
      // Mac / Linux 系统的 Bash 路径替换逻辑
      "osx": {
        "command": "mdDir='${fileDirname}'; postName='${fileBasenameNoExtension}'; imgDir=${mdDir/_posts/images}; mkdir -p \"$imgDir/$postName\""
      },
      "linux": {
        "command": "mdDir='${fileDirname}'; postName='${fileBasenameNoExtension}'; imgDir=${mdDir/_posts/images}; mkdir -p \"$imgDir/$postName\""
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}